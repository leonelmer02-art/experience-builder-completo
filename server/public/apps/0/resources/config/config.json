    },
    "widget_78": {
      "uri": "widgets/common/text/",
      "version": "1.17.0",
      "label": "Texto 4",
      "config": {
        "text": "<h3 style=\"margin: 0px 0px 15px; line-height: 1.5; text-align: left;\"><strong style=\"font-family: &quot;Avenir Next&quot;; color: rgb(255, 255, 255); font-size: 20px; letter-spacing: normal;\">¿Qué es&nbsp;</strong><strong style=\"font-family: &quot;Avenir Next&quot;; color: rgb(194, 205, 0); font-size: 20px; letter-spacing: normal;\">Ciudad Cercana?</strong></h3><p style=\"text-align: left;\"><span style=\"float: none; display: inline; letter-spacing: normal; font-size: 16px; font-family: Muli, sans-serif; color: rgb(255, 255, 255);\">Ciudad Cercana es una iniciativa que busca desarrollar espacios de vivienda bien ubicados dentro de la ciudad, donde las personas tengan fácil acceso a servicios esenciales como escuelas, farmacias, supermercados y transporte público. Su objetivo es reducir los tiempos de traslado, disminuir la dependencia del automóvil y fomentar un estilo de vida más incluyente, dinámico y sustentable en Chihuahua. Impulsa el aprovechamiento de áreas urbanas con infraestructura existente, haciéndolas más atractivas para sus habitantes.</span></p>",
        "placeholder": "Haga doble clic para editar texto",
        "style": {
          "wrap": true
        }
      },
      "id": "widget_78"
    },
