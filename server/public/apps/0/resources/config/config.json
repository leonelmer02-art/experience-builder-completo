    "widget_77": {
      "uri": "widgets/common/text/",
      "version": "1.17.0",
      "label": "Texto 3",
      "config": {
        "text": "<p style=\"text-align: left;\"><strong style=\"font-family: &quot;Avenir Next&quot;; font-size: 13px; color: var(--warning-600);\">Bienbenido a</strong></p><p style=\"text-align: left;\"><strong style=\"font-size: 30px;\">Ciudad</strong><strong> </strong><strong style=\"letter-spacing: normal; font-family: &quot;Avenir Next&quot;; font-size: 30px; color: rgb(194, 205, 0);\">Cercana</strong></p><p style=\"text-align: left;\"><strong style=\"font-size: 30px;\">Política Publica</strong></p>",
